# =============================================================================
# نسخة جاهزة للإنتاج — https://tarek-affiliate.com
# انسخ القسم المناسب فقط (لا تخلط القسمين في نفس لوحة Dokploy إن كانت منفصلة).
# =============================================================================

# -----------------------------------------------------------------------------
# [أ] خدمة الـ API (Node — Dokploy Environment / ملف .env على السيرفر)
# المنفذ: يجب أن يطابق ما يفتحه Dokploy (غالبًا PORT).
# كلمة مرور الأدمن: 8 أحرف على الأقل (شرط تسجيل الدخول في الـ API).
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=3000
MONGO_URI=mongodb://USER:PASSWORD@HOST:27017
MONGO_DB_NAME=tarekAffiliate
JWT_SECRET=ضع-سلسلة-عشوائية-طويلة-جدا-لا-تشاركها
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=ChangeMe123456
COOKIE_DOMAIN=
WEB_ORIGIN=https://tarek-affiliate.com
ADMIN_ORIGIN=https://tarek-affiliate.com

# -----------------------------------------------------------------------------
# [ب] بناء الواجهة (محليًا: انسخ الأسطر التالية إلى ملف .env.production في جذر
# المشروع ثم نفّذ npm run build — أو ضعها كمتغيرات بيئة في خط CI قبل البناء)
# مع VITE_API_BASE_URL فارغ يجب توجيه /api على نفس النطاق إلى الـ API.
# انظر: deploy/nginx-api-location.example.conf
# -----------------------------------------------------------------------------

VITE_API_BASE_URL=
VITE_WEB_APP_URL=https://tarek-affiliate.com
VITE_ADMIN_APP_URL=https://tarek-affiliate.com/admin.html
